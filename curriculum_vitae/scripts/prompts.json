{
  "shared": {
    "structure": {
      "pages": 3,
      "pageBreak": "\\newpage after page 1",
      "output": "LaTeX only. Start \\documentclass, end \\end{document}."
    },
    "pageLayout": [
      "P1: Header+Summary+Core competencies+Current role",
      "P2: Previous 2 roles (Union Investment, Saloodo!)",
      "P3: Earlier roles+Education+Technical skills",
      "Recent: 4-6 bullets. Earlier: 2-3 bullets.",
      "Use metrics, dates, technologies, achievements"
    ],
    "constraints": [
      "Exactly {{PAGES}} pages",
      "Fill all space - expand/condense as needed",
      "Maintain \\newpage placement"
    ]
  },
  "antiCv": {
    "system": [
      "Generate Anti-CV: honest failures/lessons learned.",
      "Tone: Self-deprecating, professional, mildly humorous.",
      "Content: Failed projects, rejections, mistakes, irrelevant skills.",
      "Structure: {{SHARED_PAGE_LAYOUT}}",
      "{{SHARED_OUTPUT}}"
    ],
    "fullRebuild": [
      "Create {{PAGES}}-page Anti-CV from:",
      "```markdown\n{{CAREER_DATA}}\n```",
      "Layout: {{SHARED_PAGE_LAYOUT}}",
      "Add: 'Technologies I Overhyped', 'Projects That Failed', 'Interviews I Bombed'."
    ],
    "incremental": [
      "Update Anti-CV:",
      "```latex\n{{CURRENT_CV}}\n```",
      "Changes: ```diff\n{{DIFF_DATA}}\n```",
      "Constraints: {{SHARED_CONSTRAINTS}}"
    ]
  },
  "professionalCv": {
    "system": [
      "Generate achievement-focused professional CV.",
      "Focus: Quantified impact, technical leadership, progression.",
      "Language: Action verbs, metrics, business value.",
      "Style: Clean, modern. Navy #1f4e79 headers.",
      "Structure: {{SHARED_PAGE_LAYOUT}}",
      "{{SHARED_OUTPUT}}"
    ],
    "fullRebuild": [
      "Create {{PAGES}}-page professional CV from:",
      "```markdown\n{{CAREER_DATA}}\n```",
      "Layout: {{SHARED_PAGE_LAYOUT}}",
      "Transform technical details to business impact. Quantify everything."
    ],
    "incremental": [
      "Update professional CV:",
      "```latex\n{{CURRENT_CV}}\n```",
      "Changes: ```diff\n{{DIFF_DATA}}\n```",
      "Constraints: {{SHARED_CONSTRAINTS}}",
      "Maintain professional tone and quantified achievements."
    ]
  }
}
