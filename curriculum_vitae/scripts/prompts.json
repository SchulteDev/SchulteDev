{
  "shared": {
    "structure": {
      "pages": 3,
      "pageBreak": "\\newpage after page 1",
      "output": "LaTeX only. Start \\documentclass, end \\end{document}."
    },
    "pageLayout": [
      "P1: Header+Summary+Core competencies+Current role(LBBW)",
      "P2: Previous 3 roles (Union Investment, Saloodo!, Trusted Shops)",
      "P3: Earlier roles+Education+Technical skills",
      "Recent: 4-6 bullets. Earlier: 2-3 bullets.",
      "Use metrics, dates, tech, achievements"
    ],
    "constraints": [
      "Exactly {{PAGES}} pages",
      "Fill all space - expand/condense as needed",
      "Maintain \\newpage placement"
    ],
    "templates": {
      "fullRebuild": [
        "Create {{PAGES}}-page {{CV_TYPE}} from:",
        "```markdown\n{{CAREER_DATA}}\n```",
        "Layout: {{SHARED_PAGE_LAYOUT}}",
        "{{TYPE_SPECIFIC_INSTRUCTIONS}}"
      ],
      "incremental": [
        "Update {{CV_TYPE}}:",
        "```latex\n{{CURRENT_CV}}\n```",
        "Changes: ```diff\n{{DIFF_DATA}}\n```",
        "{{SHARED_CONSTRAINTS}}",
        "{{TYPE_SPECIFIC_INSTRUCTIONS}}"
      ]
    }
  },
  "antiCv": {
    "cvType": "Anti-CV",
    "system": [
      "Generate Anti-CV: honest failures/lessons.",
      "Tone: Self-deprecating, humorous, ironic, sarcastic, no damage to any reputation.",
      "Content: Failed projects, rejections, mistakes, irrelevant skills.",
      "Structure: {{SHARED_PAGE_LAYOUT}}",
      "{{SHARED_OUTPUT}}"
    ],
    "fullRebuildInstructions": "",
    "incrementalInstructions": ""
  },
  "professionalCv": {
    "cvType": "professional CV",
    "system": [
      "Generate achievement-focused professional CV.",
      "Focus: Quantified impact, technical leadership, progression.",
      "Language: Action verbs, metrics, business value.",
      "Style: Clean, modern.",
      "Structure: {{SHARED_PAGE_LAYOUT}}",
      "{{SHARED_OUTPUT}}"
    ],
    "fullRebuildInstructions": "Transform tech details to business impact. Quantify all.",
    "incrementalInstructions": "Maintain tone and achievements."
  }
}
