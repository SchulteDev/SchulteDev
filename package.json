{
  "name": "schultedev",
  "version": "0.0.1",
  "description": "AI-powered CV generation and transformation scripts",
  "type": "module",
  "scripts": {
    "test": "npm run cv:test",
    "build": "npx tsc",
    "clean": "rm -r dist/ node_modules/",
    "cv:update": "npm run build && node dist/run-cv-update.js",
    "cv:full-rebuild": "npm run build && node dist/transform-full-rebuild.js",
    "cv:incremental": "npm run build && node dist/transform-incremental.js",
    "cv:test": "npm run build && node dist/test-local.js",
    "cv:test:full": "npm run build && node dist/test-local.js full_rebuild"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SchulteDev/SchulteDev.git"
  },
  "keywords": [
    "cv",
    "resume",
    "ai",
    "claude",
    "automation",
    "cloud-architect",
    "devops"
  ],
  "author": {
    "name": "Markus Schulte",
    "email": "mail@schulte-development.de"
  },
  "license": "EUPL-1.2",
  "bugs": {
    "url": "https://github.com/SchulteDev/SchulteDev/issues"
  },
  "homepage": "https://github.com/SchulteDev/SchulteDev",
  "dependencies": {
    "@anthropic-ai/sdk": "0.54.0",
    "axios": "1.10.0",
    "consola": "3.4.2",
    "dotenv": "16.5.0",
    "fs-extra": "11.3.0"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "22.15.31",
    "typescript": "5.8.3",
    "ts-node": "10.9.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
